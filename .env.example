# required environment variables
KICKTIPP_EMAIL=EMAIL_ADDRESS
KICKTIPP_PASSWORD=PASSWORD
KICKTIPP_NAME_OF_COMPETITION=COMPETITION_NAME 
##  (https://www.kicktipp.fr/COMPETITION_NAME/centre-pronostics)
KICKTIPP_ODDS_API_KEY=your-the-odds-api-key

# optional environment variables
KICKTIPP_HOURS_UNTIL_GAME=2
KICKTIPP_RUN_EVERY_X_MINUTES=60
OVERWRITE_TIPS=false  # Optional: Overwrite already set tips (true/false, default: false)

# allow tty
PYTHONUNBUFFERED=1

# CHROMEDRIVER_PATH=/usr/bin/chromedriver # uncomment this if you run without docker and encounter problems with the driver

JBPROD_API_TOKEN=API_JBPROD_TOKEN


ZAPIER_URL=https://hooks.zapier.com/hooks/catch/12345678/abcdefgh/

NTFY_URL=https://ntfy.your-domain.com/kicktipp-bot
NTFY_USERNAME=your-username
NTFY_PASSWORD=your-password

WEBHOOK_URL=https://your-home-assistant-url.com/api/webhook/your-webhook-id

# Optional: Group all notifications into one webhook call at the end of each run (true/false, default: false)
GROUP_NOTIFICATIONS=false

SENTRY_DSN=https://token@org.ingest.de.sentry.io/project
SENTRY_ENVIRONMENT=localhost

# Optional Odds API configuration
# KICKTIPP_ODDS_API_KEY is the API key for the-odds-api.com service
# KICKTIPP_ODDS_API_SPORT_KEY is the Odds API sport/competition endpoint to query
KICKTIPP_ODDS_API_SPORT_KEY=soccer_fifa_world_cup
# KICKTIPP_ODDS_API_REGIONS defines the region for odds (example: fr)
KICKTIPP_ODDS_API_REGIONS=fr

# Optional Kicktipp round navigation
# Use a single day with KICKTIPP_SPIELTAG_INDEX or a range with
# KICKTIPP_SPIELTAG_INDEX_START and KICKTIPP_SPIELTAG_INDEX_END.
# Example single day: KICKTIPP_SPIELTAG_INDEX=3
# Example range: KICKTIPP_SPIELTAG_INDEX_START=1 KICKTIPP_SPIELTAG_INDEX_END=16
KICKTIPP_SPIELTAG_INDEX=1
KICKTIPP_SPIELTAG_INDEX_START=1
KICKTIPP_SPIELTAG_INDEX_END=16

# Timezone for the application
TZ=Europe/Paris
